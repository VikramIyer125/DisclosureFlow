# ── Secrets / auth — NEVER commit ─────────────────────────────
# `uipath auth` writes the access token into .env. Keep it out of git.
.env
.env.*
!.env.example
*.pem
*.key

# ── Build artifacts ───────────────────────────────────────────
*.nupkg
dist/
build/
*.egg-info/
.eggs/

# ── UiPath local runtime artifacts ────────────────────────────
# `uipath run`/`invoke` write a local LangGraph checkpoint DB here.
__uipath/
*.db
.uipath/

# ── Portal runtime data ───────────────────────────────────────
# One JSON per submitted request — runtime data, not source.
portal/intake/

# ── Python caches ─────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
# NOTE: do NOT ignore uv.lock — it is committed for reproducible builds.

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/launch.json           
hello/
ASSUMPTIONS.md

# ── Keep committed (listed here as a reminder — do not ignore): ─
# uipath.json, bindings.json, entry-points.json, project.uiproj, .uipath/
# uv.lock, pyproject.toml